project_name = "finpay"
environment  = "dev"
aws_region   = "ap-northeast-2"

# Optional: use these when applying to another AWS account through an assumed role.
aws_profile              = ""
assume_role_arn          = ""
assume_role_session_name = "finpay-terraform"

vpc_cidr            = "10.0.0.0/16"
az_names            = ["ap-northeast-2a", "ap-northeast-2c"]
public_subnet_cidrs = ["10.0.0.0/24", "10.0.1.0/24"]
app_subnet_cidrs    = ["10.0.10.0/24", "10.0.11.0/24"]
db_subnet_cidrs     = ["10.0.20.0/24", "10.0.21.0/24"]

allowed_http_cidr_blocks = ["0.0.0.0/0"]
enable_cloudfront_origin_only_alb_access = false
alb_certificate_arn      = ""
acm_certificate_arn      = ""
enable_https_listener    = false
enable_http_redirect     = false
# Requires enable_https_listener=true and an ACM certificate for the ALB origin.
enable_cloudfront_origin_https = false
# Uses HTTPS from ALB target groups to EC2 app instances.
enable_alb_to_app_https = false
cloudfront_origin_domain_name  = ""
cloudfront_aliases             = []
cloudfront_acm_certificate_arn = ""
enable_cloudfront_standard_logs = true
enable_cloudfront_connection_logs = false

# Viewer mTLS between clients and CloudFront. Generate local test material with:
# ./scripts/generate-viewer-mtls-certs.sh
enable_cloudfront_viewer_mtls                    = false
cloudfront_viewer_mtls_mode                      = "required"
cloudfront_viewer_mtls_ca_bundle_path            = "certs/mtls/client-ca-bundle.pem"
cloudfront_viewer_mtls_ca_bundle_s3_key          = "cloudfront-viewer-mtls/client-ca-bundle.pem"
cloudfront_viewer_mtls_trust_store_name          = ""
cloudfront_viewer_mtls_advertise_ca_names        = true
cloudfront_viewer_mtls_ignore_certificate_expiry = false

app_instance_type    = "t3.micro"
app_desired_capacity = 1
app_min_size         = 1
app_max_size         = 2

db_instance_class = "db.t4g.micro"
db_name           = "finpay"
rds_sslmode       = "require"
alert_email       = ""

enable_alb_access_logs                      = false
enable_guardduty                            = false
enable_securityhub                          = false
enable_aws_config                           = false
rds_backup_retention_period                 = 1
enable_log_object_lock                      = false
log_object_lock_retention_days              = 365
standard_cloudwatch_log_retention_days      = 365
# CloudWatch Logs does not support 730 directly; 731 is the two-year retention value.
audit_cloudwatch_log_retention_days                    = 731
log_lifecycle_transition_ia_days                       = 90
log_lifecycle_transition_glacier_days                  = 180
alb_log_lifecycle_expiration_days                      = 365
central_log_lifecycle_expiration_days                  = 730
cloudfront_standard_log_lifecycle_expiration_days      = 365
cloudfront_connection_log_lifecycle_expiration_days    = 730

# Additional buckets allowed through the S3 Gateway Endpoint policy.
# The app artifact bucket is automatically allowed by the root module.
s3_gateway_endpoint_bucket_arns = []

# Keep false until SSM and app runtime endpoint calls are verified.
enable_interface_endpoint_policy_restrictions = false

waf_rate_rule_action = "count"
waf_rate_limits = {
  auth         = 300
  payments     = 500
  transactions = 1000
  ops          = 100
  audit        = 100
}
